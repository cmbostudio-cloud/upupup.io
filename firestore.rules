rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOwnerUid(uid) {
      return request.resource.data.uid == uid;
    }

    match /infiniteLeaderboard/{uid} {
      // 랭킹은 누구나 읽기 가능
      allow read: if true;

      // 로그인한 본인 문서만 생성/갱신 가능
      allow create, update: if isOwner(uid)
        && hasOwnerUid(uid)
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 20;

      // 삭제는 금지
      allow delete: if false;
    }

    match /userData/{uid} {
      // Google 계정 저장 데이터는 로그인한 본인만 읽기/생성/갱신 가능
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && hasOwnerUid(uid);
      allow delete: if false;
    }

    match /guestUserData/{uid} {
      // 익명 게스트 클라우드 저장을 다시 켤 때를 위한 규칙
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && hasOwnerUid(uid);
      allow delete: if false;
    }
  }
}
